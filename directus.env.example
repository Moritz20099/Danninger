# Directus (Docker) – nach directus.env kopieren
# cp directus.env.example directus.env

DIRECTUS_PORT=8055

KEY=change-me-to-a-random-string
SECRET=change-me-to-another-random-string

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=directus

DB_CLIENT=pg
DB_HOST=database
DB_PORT=5432
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=directus

# CORS für Nuxt Dev-Server (Browser-Requests)
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

PUBLIC_URL=http://localhost:8055
